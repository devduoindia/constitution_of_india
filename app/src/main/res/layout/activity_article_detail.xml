<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/primary"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_back_detail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_nav_arrow_back"
            android:padding="12dp"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Article Detail"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:paddingStart="4dp" />

        <ImageView
            android:id="@+id/iv_tts"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_play_arrow"
            android:padding="12dp"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/iv_font_decrease"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_font_decrease"
            android:padding="10dp"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/iv_font_increase"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_font_increase"
            android:padding="10dp"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/iv_bookmark_detail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_bookmark_outline"
            android:padding="12dp"
            app:tint="@color/accent" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Article number + title header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/tv_article_number_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/article_label"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_article_title_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_article_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="8dp"
                android:padding="20dp"
                android:textIsSelectable="true" />

            <!-- Note Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Notes"
                        android:textStyle="bold"
                        android:textColor="@color/accent"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tap to add a personal note for this article..."
                        android:textSize="14sp"
                        android:background="@android:color/transparent"
                        android:gravity="top"
                        android:minLines="3" />

                    <Button
                        android:id="@+id/btn_save_note"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Save Note"
                        android:textSize="12sp"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/white" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom navigation (prev / next) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_prev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_nav_arrow_back"
            android:padding="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/nav_arrow"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_nav_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:minWidth="80dp" />

        <ImageView
            android:id="@+id/iv_next"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_nav_arrow_forward"
            android:padding="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/nav_arrow"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>
